PORT=3001

# Telegram Bot（@BotFather 取得）
TELEGRAM_BOT_TOKEN=
# 你的 Telegram userId，可用 @userinfobot 查詢
ALLOWED_TELEGRAM_USER_IDS=

# polling（本機開發）| webhook（部署到公網 HTTPS）
TELEGRAM_MODE=polling
WEBHOOK_PATH=/telegram/webhook
# webhook 模式必填，例如 https://your.domain/telegram/webhook
WEBHOOK_URL=

# OpenAI（閒聊、意圖分類、網頁摘要）
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# 供 n8n 回傳分析結果時驗證，請自行產生隨機字串
INTERNAL_API_SECRET=

# llm = AI 判斷意圖 scrape/dev/ops/chat（預設）；rules = 關鍵字規則
INTENT_ROUTER=llm

# Cursor SDK（開發任務）
# 取得：https://cursor.com/dashboard/integrations
# 需要 Node.js >= 22.13
CURSOR_API_KEY=
AGENT_MODEL=composer-2.5
# local = 在 DEFAULT_CWD 本機/容器路徑直接開發；cloud = Cursor Cloud Agent（建議）
DEV_RUNTIME=local
# Cloud Agent 目標 repo（逗號分隔，格式 owner/repo）
CLOUD_REPOS=
# Cloud Agent 預設分支（通常 main）
CLOUD_BASE_BRANCH=main
# Cloud Agent 完成後自動開 PR
CLOUD_AUTO_CREATE_PR=true
# Cloud Agent 在 CI/自動化中建議關閉 reviewer request
CLOUD_SKIP_REVIEWER_REQUEST=true
# Agent 操作的工作目錄（你的 repo 根目錄）
DEFAULT_CWD=d:/桌面/code/inwanding
# 允許 /cwd 切換的根目錄（逗號分隔，預設同 DEFAULT_CWD）
ALLOWED_CWD_ROOTS=
# 開發任務自動加上「簡短、列點」提示（設 false 關閉）
DEV_BRIEF_REPLY=true
RUN_TIMEOUT_MS=600000

SESSION_DB_PATH=./data/bot.db

PLAYWRIGHT_SERVICE_URL=http://127.0.0.1:3100
SCRAPE_TIMEOUT_MS=120000

# inline = Bot 直接編排（預設）；n8n = 改走 n8n webhook（需回傳 summary）
SCRAPE_MODE=inline
N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/scrape-note

# Ops 主機操作
OPS_ENABLED=true
# 預設 false。Production 不應啟用，且 Bot 容器不得掛載 docker.sock。
OPS_DOCKER_ENABLED=false
# 允許查 log 的容器名稱（逗號分隔）
# 本機 compose：telegram-agent-bot,playwright-service
# 遠端 infra：svc-telegram-bot,svc-telegram-playwright,svc-line-bot,edge-nginx
OPS_ALLOWED_CONTAINERS=telegram-agent-bot,playwright-service
# 健康檢查 URL（逗號分隔；未設則用 bot + playwright /health）
# OPS_HEALTH_URLS=http://127.0.0.1:3001/health,http://telegram-playwright:3100/health
OPS_COMMAND_TIMEOUT_MS=30000
OPS_LOG_TAIL_LINES=50

# GitHub 查詢（Phase 1 唯讀）
# 建議使用 read-only fine-grained PAT 或 classic token（僅 repo read）
GITHUB_TOKEN=
GITHUB_ALLOWED_REPOS=Aiden4939/telegram-agent-bot
GITHUB_ISSUE_LIMIT=10

# Task guardrails（Phase 1B）
TASK_MAX_MODEL_CALLS=30
TASK_MAX_TOOL_CALLS=80
TASK_MAX_RUNTIME_MS=900000
TASK_MAX_ESTIMATED_COST=5
DAILY_MAX_ESTIMATED_COST=50
MONTHLY_MAX_ESTIMATED_COST=500
LOG_MAX_LINES=80
LOG_MAX_BYTES=12000
TASK_APPROVAL_TTL_MS=900000
TOOL_CALL_TIMEOUT_MS=120000
MODEL_CALL_TIMEOUT_MS=120000
TASK_HEARTBEAT_TIMEOUT_MS=300000
USER_MESSAGE_PER_MINUTE_LIMIT=15
USER_CONCURRENT_DEV_TASK_LIMIT=1
GLOBAL_CONCURRENT_AGENT_LIMIT=3
MIN_AGENT_START_INTERVAL_MS=60000
TASK_CI_POLL_INTERVAL_SECONDS=20
TASK_CI_TIMEOUT_SECONDS=1800
TASK_CI_MAX_POLLS=120
TASK_MAX_AGENT_RESUMES=3
TASK_MAX_CI_FIX_ATTEMPTS=3
