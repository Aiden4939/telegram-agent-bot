PORT=3001

# Telegram Bot（@BotFather 取得）
TELEGRAM_BOT_TOKEN=
# 你的 Telegram userId，可用 @userinfobot 查詢
ALLOWED_TELEGRAM_USER_IDS=

# OpenAI（閒聊、意圖分類、網頁摘要）
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# 供 n8n 回寫筆記時驗證，請自行產生隨機字串
INTERNAL_API_SECRET=

# llm = AI 判斷意圖 scrape/dev/chat（預設）；rules = 關鍵字規則
INTENT_ROUTER=llm

# Cursor SDK（開發任務）
# 取得：https://cursor.com/dashboard/integrations
# 需要 Node.js >= 22.13
CURSOR_API_KEY=
AGENT_MODEL=composer-2.5
# Agent 操作的工作目錄（你的 repo 根目錄）
DEFAULT_CWD=d:/桌面/code/inwanding
RUN_TIMEOUT_MS=600000

SESSION_DB_PATH=./data/bot.db

PLAYWRIGHT_SERVICE_URL=http://127.0.0.1:3100
SCRAPE_TIMEOUT_MS=120000

# inline = Bot 直接編排（預設）；n8n = 改走 n8n webhook
SCRAPE_MODE=inline
N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/scrape-note
