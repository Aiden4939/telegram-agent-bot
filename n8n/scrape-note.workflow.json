        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"model\": \"gpt-4o-mini\", \"messages\": [ { \"role\": \"system\", \"content\": \"你是筆記整理助理，用繁體中文輸出精簡摘要。\" }, { \"role\": \"user\", \"content\": \"網址：\" + $('Webhook').item.json.body.url + \"\\n標題：\" + $json.title + \"\\n內容：\\n\" + ($json.text || '').slice(0, 12000) } ] } }}",
        "options": {}
      },
      "id": "openai",
      "name": "OpenAI Summarize",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BOT_INTERNAL_URL }}/internal/notes",
