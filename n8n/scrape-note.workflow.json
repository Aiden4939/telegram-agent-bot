              "value": "={{ $env.INTERNAL_API_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"chatId\": $('Webhook').item.json.body.chatId, \"sourceUrl\": $('Webhook').item.json.body.url, \"title\": $('Playwright Scrape').item.json.title, \"summary\": $json.choices[0].message.content, \"rawText\": $('Playwright Scrape').item.json.text } }}",
        "options": {}
      },
      "id": "save",
      "name": "Save Note",
      "type": "n8n-nodes-base.httpRequest",
